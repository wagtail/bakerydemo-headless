    "@types/node": "^24.11.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^29.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  }
